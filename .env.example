# Local bridge HTTP server
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=3099
BRIDGE_AUTO_SEND=false

# BlueBubbles server
BLUEBUBBLES_BASE_URL=http://127.0.0.1:1234
BLUEBUBBLES_PASSWORD=
BLUEBUBBLES_SEND_TEXT_PATH=/api/v1/message/text
BLUEBUBBLES_THREADED_REPLIES=false

# Allowlist at least one target before receiving webhooks.
# Examples:
# ALLOWED_CHAT_GUIDS=any;-;example-contact
# ALLOWED_HANDLES=example-contact,+15555550123
ALLOWED_CHAT_GUIDS=
ALLOWED_HANDLES=

# Codex Desktop local debug surface
# Current limitation: the bridge uses whichever Codex Desktop thread is already open.
# Named thread selection/routing is planned but not implemented yet.
CODEX_APP_PATH=/Applications/Codex.app
CODEX_REMOTE_DEBUG_PORT=9229
CODEX_REMOTE_DEBUG_URL=http://127.0.0.1:9229
CODEX_WAKE_BEFORE_PROMPT=true
CODEX_WAKE_APP_BEFORE_PROMPT=false
CODEX_BRING_TO_FRONT_BEFORE_PROMPT=false
CODEX_CDP_REQUEST_TIMEOUT_MS=60000
CODEX_RESPONSE_TIMEOUT_MS=900000

# Local state. Do not commit this directory.
BRIDGE_STATE_DIR=./state
ATTACHMENT_DIR=./state/attachments
MESSAGE_INDEX_PATH=./state/bluebubbles-message-index.jsonl
INCOMING_JOB_LOG_PATH=./state/bluebubbles-incoming-jobs.jsonl
AUDIO_TRANSCRIPT_CACHE_PATH=./state/audio-transcripts.json
OUTGOING_DEDUPE_TTL_MS=60000
INCOMING_BUNDLE_DELAY_MS=1800

# Typing indicators can get sticky on some iMessage/BlueBubbles setups.
# Keep disabled unless your setup reliably clears them.
TYPING_INDICATORS_ENABLED=false

# Optional audio transcription.
# Incoming audio is downloaded locally first. If enabled and OPENAI_API_KEY is set,
# the bridge sends that local audio file to the configured transcription endpoint.
# Leave OPENAI_API_KEY blank to avoid transcription API calls.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
AUDIO_TRANSCRIPTION_ENABLED=true
AUDIO_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
AUDIO_TRANSCRIPTION_TIMEOUT_MS=60000
AUDIO_TRANSCRIPTION_MAX_BYTES=26214400
AUDIO_TRANSCRIPTION_MAX_DURATION_SECONDS=60

# Optional custom agent/persona instructions.
# Prefer BRIDGE_SYSTEM_PROMPT_FILE for private rules.
BRIDGE_SYSTEM_PROMPT=
BRIDGE_SYSTEM_PROMPT_FILE=./prompts/default-system-prompt.md
